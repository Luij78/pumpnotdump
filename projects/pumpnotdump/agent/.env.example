# pump.notdump.fun Agent Configuration
# Copy this to .env and fill in values

# Colosseum API Key (from memory/colosseum-hackathon.md)
COLOSSEUM_API_KEY=your_api_key_here

# Solana RPC Endpoint
SOLANA_RPC=https://api.devnet.solana.com

# Program ID (will be set after deployment)
PROGRAM_ID=your_deployed_program_id_here

# Agent Configuration
AGENT_ID=911
POLL_INTERVAL_MS=30000

# Demo Mode (set to true to test without blockchain calls)
DEMO_MODE=false
